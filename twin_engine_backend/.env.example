# ============================================================
# TwinEngine Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in values for your environment.
#   cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# Django Core
# -----------------------------------------------------------
DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Deployment environment: development | staging | production
DEPLOY_ENV=development

# Set to "true" in Docker containers (switches to stdout-only logging)
CONTAINER=false

# -----------------------------------------------------------
# Database
# For local dev (SQLite):
#   DATABASE_URL=sqlite:///db.sqlite3
# For production (Neon / Azure PostgreSQL):
#   DATABASE_URL=postgresql://user:pass@host:5432/twinengine?sslmode=require
# -----------------------------------------------------------
DATABASE_URL=sqlite:///db.sqlite3

# -----------------------------------------------------------
# CORS — Allowed frontend origins (comma-separated)
# -----------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------
# CSRF — Trusted origins (comma-separated, usually same as CORS)
# -----------------------------------------------------------
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------
# Redis — Used by Django Channels (WebSockets) & Celery
# Leave empty to use InMemoryChannelLayer (dev only)
# -----------------------------------------------------------
REDIS_URL=

# -----------------------------------------------------------
# Azure OpenAI (for GPT-4o report generation)
# -----------------------------------------------------------
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# -----------------------------------------------------------
# Cloudinary (media storage)
# -----------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------
# Email (SMTP — for notifications, optional)
# -----------------------------------------------------------
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# -----------------------------------------------------------
# Sentry (error monitoring, optional)
# -----------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------
# Logging
# -----------------------------------------------------------
LOG_LEVEL=DEBUG

# -----------------------------------------------------------
# Server (used by Docker / Gunicorn)
# -----------------------------------------------------------
PORT=8000
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
CELERY_CONCURRENCY=2
